{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "./cmd/memos", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3001
    },
    {
      "name": "frontend-verify",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "3012", "--strictPort"],
      "cwd": "web",
      "port": 3012
    }
  ]
}
